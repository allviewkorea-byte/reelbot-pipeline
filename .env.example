# FastAPI 백엔드 주소 (Phase 2 — UI ↔ API 연결)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# WaveSpeed API 키 — 캐릭터 라이브러리 이미지 생성(Z-Image Turbo)에 사용
WAVESPEED_API_KEY=

# YouTube Data API v3 키 — 트렌드 분석(인기 영상 검색 + 댓글 수집)에 사용.
# 실제 분석은 FastAPI 백엔드에서 수행하므로 travel-pipeline/.env 에도 동일 키 필요.
YOUTUBE_API_KEY=AIzaSy...

# 콘티 생성 시 reference로 사용할 기본 캐릭터 front 이미지
# 기본값: 김이안 (char_1779198264788). 비워두면 config.py 가 리포 내 경로로 자동 설정.
CHARACTER_LIBRARY_FRONT=public/character-seeds/char_1779198264788/front.png

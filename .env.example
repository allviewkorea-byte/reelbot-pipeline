# FastAPI 백엔드 주소 (Phase 2 — UI ↔ API 연결)
# localhost 대신 127.0.0.1 권장 — localhost는 IPv6(::1)로 해석돼
# uvicorn(IPv4)과 연결되지 않고 무한 대기할 수 있음.
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000

# WaveSpeed API 키 — 캐릭터 라이브러리 이미지 생성(Z-Image Turbo)에 사용
WAVESPEED_API_KEY=

# Supabase — 캐릭터 이미지(Storage) + 메타데이터(Postgres) 저장에 사용.
# 둘 다 서버사이드 전용. NEXT_PUBLIC_ 접두사 절대 금지 (secret key는 특히 노출되면 안 됨).
# Vercel 환경변수에도 동일하게 추가해야 프로덕션에서 캐릭터 생성이 동작함.
SUPABASE_URL=
SUPABASE_SECRET_KEY=

# Anthropic Claude — 제목 카피·가사·플랜·감성멘트 생성 (필수)
ANTHROPIC_API_KEY=sk-ant-...

# YouTube Data API v3 키 — 트렌드 분석(인기 영상 검색 + 댓글 수집)에 사용.
# 실제 분석은 FastAPI 백엔드에서 수행하므로 travel-pipeline/.env 에도 동일 키 필요.
YOUTUBE_API_KEY=AIzaSy...

# 콘티 생성 시 reference로 사용할 기본 캐릭터 front 이미지
# 기본값: 김이안 (char_1779198264788). 비워두면 config.py 가 리포 내 경로로 자동 설정.
CHARACTER_LIBRARY_FRONT=public/character-seeds/char_1779198264788/front.png

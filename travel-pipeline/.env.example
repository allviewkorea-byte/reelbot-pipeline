# Copy this file to `.env` (same directory) and fill in real values.
# `.env` itself is gitignored.

# ── 필수 키 ──────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_STREET_VIEW_KEY=AIza...

# ── KIE (Kling AI) ──────────────────────────────────────
# 단일 키 방식. Authorization: Bearer {KIE_API_KEY}
# `--seedance-mode kie` 사용 시에만 필요.
KIE_API_KEY=

# 구(舊) access/secret 2키 방식 (단일 KIE_API_KEY 미사용 시에만 필요).
KIE_ACCESS_KEY=
KIE_SECRET_KEY=

# ── WaveSpeed AI (Phase 3) ──────────────────────────────
# 단일 키로 Z-Image Turbo(콘티) + Kling v3(영상) 호출.
# 없어도 빌드/실행 OK — 자동으로 기존 모델(gpt-image-1 / Kling v1)로 fallback.
WAVESPEED_API_KEY=

# ── Seedance (legacy, 현재 사용 안 함이면 비워둬도 됨) ──
SEEDANCE_API_KEY=

# ── YouTube 업로드 (--skip-upload 시 불필요) ────────────
YOUTUBE_CLIENT_SECRETS_FILE=client_secrets.json

# ── YouTube Data API v3 (트렌드 분석) ───────────────────
# 무료 quota 1만 units/일. 인기 영상 검색 + 댓글 수집에 사용.
YOUTUBE_API_KEY=AIzaSy...

# ── 캐릭터 라이브러리 (옵션) ────────────────────────────
# UI 캐릭터 라이브러리에서 만든 이미지를 콘티/영상 reference로 쓸 때 사용.
CHARACTER_LIBRARY_FRONT=

# ── 산출물 공개 주소 (static 파일 URL 생성) ─────────────
# 콘티/영상 산출물 URL의 베이스. 배포 시 Railway 도메인, 로컬은 아래 기본값.
PUBLIC_BASE_URL=http://localhost:8000

# ── Rooftop Music (sunoapi.org 음악 생성) ───────────────
# 음악 생성 어댑터 키. 인증: Authorization: Bearer {SUNOAPI_ORG_KEY}
SUNOAPI_ORG_KEY=
# 콜백 수신용 Railway 공개 URL (선택). 있으면 callBackUrl 자동 구성, 없으면 폴링만.
# 예) https://adventurous-renewal.up.railway.app
MUSIC_CALLBACK_BASE_URL=
# 음악 마스터 전용 R2 버킷(Lifecycle 자동삭제 없음 — suno 15일 삭제 대비 영구보존).
# 미설정 시 기본 videos 버킷 폴백(7일 삭제 경고). R2_* 자격증명은 기존 것 재활용.
R2_MUSIC_BUCKET=
R2_MUSIC_PUBLIC_BASE_URL=
